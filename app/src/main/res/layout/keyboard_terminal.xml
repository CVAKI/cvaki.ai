<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ── Top bar ────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:orientation="horizontal"
        android:background="#001A00">

        <TextView
            android:id="@+id/tv_term_shell_label"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text=">_ Terminal"
            android:textColor="#00FF41"
            android:textSize="9sp"
            android:gravity="center_vertical"
            android:paddingStart="6dp"/>

        <Button
            android:id="@+id/btn_term_restart"
            android:layout_width="52dp"
            android:layout_height="match_parent"
            android:text="↺ Reset"
            android:textSize="8sp"
            android:textColor="#FFFFFF"
            android:background="#1A1A00"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btn_toggle_output"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:text="▲ Output"
            android:textSize="9sp"
            android:textColor="#000000"
            android:background="#00FF41"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btn_import_right"
            android:layout_width="55dp"
            android:layout_height="match_parent"
            android:text="←In"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:background="#1A3A1A"
            android:padding="0dp"/>

    </LinearLayout>

    <!-- ── Output panel (collapsible) ────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/sv_terminal_output"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#000000"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tv_terminal_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF41"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="4dp"
            android:textIsSelectable="true"
            android:text="CVA Terminal v1.0&#10;$ "/>

    </ScrollView>

    <!-- ── Input line — always visible, shows what you're typing ─────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="#001200">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:id="@+id/tv_term_input_line"
            android:text="$ █"
            android:textColor="#00FF41"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:singleLine="true"
            android:ellipsize="start"/>

        <Button
            android:id="@+id/btn_import_left"
            android:layout_width="55dp"
            android:layout_height="match_parent"
            android:text="←In"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#00FF41"
            android:background="#0A1A0A"
            android:padding="0dp"/>

    </LinearLayout>

    <!-- ── Always-visible terminal keyboard ──────────────────────────────── -->
    <LinearLayout
        android:id="@+id/terminal_keyboard_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#000814"
        android:padding="2dp"/>

    <!-- Keep this view for legacy reference but it is not used for hiding anymore -->
    <LinearLayout
        android:id="@+id/terminal_slide_keyboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"/>

</LinearLayout>