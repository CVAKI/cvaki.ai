<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0D0D1A">

    <!-- ── Navigation bar ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:background="#08080F"
        android:paddingStart="2dp"
        android:paddingEnd="2dp">

        <Button
            android:id="@+id/btn_nav_normal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⌨ Keys"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#536DFE"
            android:layout_margin="2dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/btn_nav_hash"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="# Hash"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#263238"
            android:layout_margin="2dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/btn_nav_terminal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text=">_ Term"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#263238"
            android:layout_margin="2dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/btn_nav_brain"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🧠 CVA"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#263238"
            android:layout_margin="2dp"
            android:padding="0dp" />

    </LinearLayout>

    <!-- ── Section container ───────────────────────────────────────────── -->

    <include
        android:id="@+id/section_normal"
        layout="@layout/keyboard_normal"
        android:visibility="visible" />

    <include
        android:id="@+id/section_hash"
        layout="@layout/keyboard_hash"
        android:visibility="gone" />

    <include
        android:id="@+id/section_terminal"
        layout="@layout/keyboard_terminal"
        android:visibility="gone" />

    <include
        android:id="@+id/section_brain"
        layout="@layout/keyboard_brain"
        android:visibility="gone" />

</LinearLayout>