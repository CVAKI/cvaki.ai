<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Core ─────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Overlay (float bubble) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Wake lock (TerminalService) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Accessibility (gesture injection) -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- Storage -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Sensor & media -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Contacts & comms -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.DayNight.NoActionBar"
        android:usesCleartextTraffic="true"
        android:extractNativeLibs="true"
        android:name=".CvaApplication"
        xmlns:tools="http://schemas.android.com/tools">

        <!--
            android:usesCleartextTraffic="true"  ← CHANGED from false to true
            The Termux bootstrap ZIP is downloaded over HTTPS but some CDN mirrors
            redirect through HTTP.  Set to true to avoid NetworkSecurityException.
            You can restrict this further with a network_security_config.xml later.

            android:name=".CvaApplication"       ← ADDED
            Wires in TermuxApplication.onAppCreate() so bootstrap dirs are created
            before any Activity or Service touches the filesystem.
        -->

        <!-- ── Splash — launcher entry point ──────────────────────────────── -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Main / Settings Activity ───────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:launchMode="singleTop" />

        <!-- ── Screen capture permission trampoline ────────────────────────── -->
        <activity
            android:name=".ScreenCapturePermissionActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false" />

        <!-- ── Task Allocation Activity ─────────────────────────────────────── -->
        <activity
            android:name=".TaskAllocationActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="portrait" />

        <!-- ── TmuxDoctor — self-heal terminal environment ───────────────────── -->
        <activity
            android:name=".TmuxDoctorActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

        <!-- ── Terminal foreground service ───────────────────────────────────── -->
        <!--
            foregroundServiceType="specialUse|dataSync":
              • specialUse  — covers the interactive terminal session (exec of binaries)
              • dataSync    — covers bootstrap ZIP downloads / package installs
            Both are needed on API 34+ to avoid ForegroundServiceDidNotStartInTimeException.
        -->
        <service
            android:name=".TerminalService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse|dataSync" />

        <!-- ── IME Service ────────────────────────────────────────────────── -->
        <!--
            FIX NOTE (KeyboardService NPE): KeyboardService.setupTerminalSection() calls
            manager.setDoctorCallback() when the view is shown, but TerminalManager may be
            null if TerminalService hasn't bound yet. In KeyboardService.java add a null
            guard at line ~560:
              if (manager != null) manager.setDoctorCallback(doctorCallback);
            Nothing to fix in the manifest for this crash.
        -->
        <service
            android:name=".KeyboardService"
            android:label="@string/keyboard_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- ── Basic float overlay ──────────────────────────────────────────── -->
        <!--
            FIX: InflateException at overlay_bubble.xml line 65 —
            "UnsupportedOperationException: Failed to resolve attribute at index 13"
            Root cause: overlay_bubble.xml uses ?attr/colorPrimary / ?attr/selectableItemBackground
            (AppCompat theme attributes). When LayoutInflater runs inside a Service, it uses the
            ApplicationContext which defaults to Theme.DeviceDefault.Light.DarkActionBar — that theme
            has NO attr/colorPrimary, causing the crash.
            Fix: declare the service with an AppCompat theme so the LayoutInflater context has all
            required attributes. In OverlayService.java also wrap the context:
              ContextThemeWrapper themed = new ContextThemeWrapper(this, R.style.Theme_AppCompat);
              LayoutInflater inflater = LayoutInflater.from(themed);
        -->
        <service
            android:name=".OverlayService"
            android:exported="false"
            android:theme="@style/Theme.AppCompat"
            android:foregroundServiceType="specialUse" />

        <!-- ── Smart AI overlay (screen capture + gesture automation) ──────── -->
        <!--
            FIX (MediaProjection crash 1): foregroundServiceType="mediaProjection" is declared
            here, but the service must call startForeground(id, notification,
            ServiceInfo.FOREGROUND_SERVICE_TYPE_MEDIA_PROJECTION) BEFORE getMediaProjection()
            is called on the token. See MediaProjectionGate.java for the correct sequence.

            FIX (theme): same AppCompat theme for any overlay inflation in this service.
        -->
        <service
            android:name=".SmartOverlayService"
            android:exported="false"
            android:theme="@style/Theme.AppCompat"
            android:foregroundServiceType="mediaProjection" />

        <!-- ── Accessibility Service ──────────────────────────────────────── -->
        <service
            android:name=".CVAAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Android 14+ (API 34): foregroundServiceType="specialUse" requires this
             property to explain why specialUse is needed. Without it the app will be
             rejected from the Play Store and may show a warning on device. -->
        <property
            android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
            android:value="CVA runs an interactive Linux terminal (bash/busybox) and
                           bootstrap package installer as a foreground process. This
                           requires specialUse because no other foreground service type
                           (dataSync, mediaPlayback, etc.) covers long-running shell
                           process execution." />

    </application>

</manifest>