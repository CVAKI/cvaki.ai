<?xml version="1.0" encoding="utf-8"?>
<!--
    res/drawable/splash_scanlines.xml
    Repeating 2px-on / 2px-off horizontal scanline texture.
    Used as the background of the scanline overlay View.
    Alpha is set programmatically to ~0.07 so it's very subtle.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!--
        True repeating scanlines require a BitmapDrawable tile.
        This shape gives a very light semi-transparent dark overlay as a fallback.
        For a real scanline tile, place a 1×4 px PNG (2px #000 / 2px transparent)
        at res/drawable/scanline_tile.png and reference it as:
            <bitmap android:src="@drawable/scanline_tile" android:tileMode="repeat"/>
    -->
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#22000000"
        android:centerColor="#00000000"
        android:endColor="#22000000"/>
</shape>