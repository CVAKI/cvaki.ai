<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:paddingBottom="4dp">

    <!-- ── Banner ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:background="#0F0F0F"
        android:gravity="center_vertical">

        <!-- Orange left accent bar -->
        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="#FF6A1A"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="# HASH MODE  —  output encrypted"
            android:textSize="9sp"
            android:textColor="#FF6A1A"
            android:gravity="center_vertical"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="8dp"/>

        <!-- Toggle translator -->
        <Button
            android:id="@+id/btn_toggle_translator"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:text="⇄ Translate"
            android:textSize="9sp"
            android:textColor="#0A0A0A"
            android:fontFamily="sans-serif-medium"
            android:background="#FF6A1A"
            android:padding="0dp"/>

    </LinearLayout>

    <!-- ── Translator panel (hidden by default) ──────────────────────────── -->
    <LinearLayout
        android:id="@+id/translator_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F0F0F"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PASTE HASHED OR PLAIN TEXT"
            android:textColor="#555555"
            android:textSize="9sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-medium"
            android:paddingBottom="5dp"/>

        <!-- Input field -->
        <EditText
            android:id="@+id/et_translate_input"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Paste text to translate…"
            android:textColor="#FFFFFF"
            android:textColorHint="#333333"
            android:background="#141414"
            android:padding="8dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:scrollbars="vertical"/>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:layout_marginTop="5dp">

            <Button
                android:id="@+id/btn_hash_to_plain"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Hash → Plain"
                android:textSize="9sp"
                android:textColor="#CCCCCC"
                android:fontFamily="sans-serif-medium"
                android:background="#1A1A1A"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btn_plain_to_hash"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Plain → Hash"
                android:textSize="9sp"
                android:textColor="#0A0A0A"
                android:fontFamily="sans-serif-medium"
                android:background="#FF6A1A"
                android:layout_marginEnd="2dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btn_copy_translation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📋 Copy"
                android:textSize="9sp"
                android:textColor="#CCCCCC"
                android:fontFamily="sans-serif-medium"
                android:background="#1A1A1A"
                android:padding="0dp"/>

        </LinearLayout>

        <!-- Result label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESULT"
            android:textColor="#555555"
            android:textSize="9sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-medium"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <!-- Output -->
        <TextView
            android:id="@+id/tv_translate_output"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="—"
            android:textColor="#FF6A1A"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="#141414"
            android:padding="8dp"
            android:scrollbars="vertical"
            android:textIsSelectable="true"/>

    </LinearLayout>

    <!-- Thin separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A"/>

    <!-- ── Keyboard rows (built programmatically) ─────────────────────────── -->
    <LinearLayout
        android:id="@+id/keyboard_rows_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="3dp"/>

</LinearLayout>