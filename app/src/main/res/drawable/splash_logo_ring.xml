<?xml version="1.0" encoding="utf-8"?>
<!--
    res/drawable/splash_logo_ring.xml
    Orange ring that surrounds the CVA letters on the splash screen.
    Thin stroke only (no fill) so the dark background shows through.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <stroke
        android:width="2.5dp"
        android:color="#FF6A1A"/>
    <solid android:color="#00000000"/>
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp"/>
</shape>