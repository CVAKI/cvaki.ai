<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0D0D1A"
    android:paddingBottom="4dp">

    <!-- ── Banner ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:orientation="horizontal"
        android:background="#08080F">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="# HASH MODE  —  keys normal, output encrypted"
            android:textSize="9sp"
            android:textColor="#536DFE"
            android:gravity="center_vertical"
            android:paddingStart="6dp"/>

        <!-- Toggle translator -->
        <Button
            android:id="@+id/btn_toggle_translator"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:text="⇄ Translate"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:background="#283593"
            android:padding="0dp"/>

    </LinearLayout>

    <!-- ── Translator panel (hidden by default) ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/translator_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0A1E"
        android:padding="6dp"
        android:visibility="gone">

        <!-- Input row -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste hashed OR plain text here:"
            android:textColor="#90A4AE"
            android:textSize="10sp"
            android:paddingBottom="3dp"/>

        <EditText
            android:id="@+id/et_translate_input"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Paste text to translate…"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#1A1A2E"
            android:padding="6dp"
            android:textSize="12sp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:scrollbars="vertical"/>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btn_hash_to_plain"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Hash → Plain"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:background="#1A237E"
                android:layout_marginEnd="3dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btn_plain_to_hash"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Plain → Hash"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:background="#4A148C"
                android:layout_marginEnd="3dp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btn_copy_translation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📋 Copy"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:background="#004D40"
                android:padding="0dp"/>

        </LinearLayout>

        <!-- Output -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Result:"
            android:textColor="#90A4AE"
            android:textSize="10sp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"/>

        <TextView
            android:id="@+id/tv_translate_output"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="—"
            android:textColor="#00E5FF"
            android:textSize="12sp"
            android:background="#050510"
            android:padding="6dp"
            android:scrollbars="vertical"
            android:textIsSelectable="true"/>

    </LinearLayout>

    <!-- ── Keyboard rows (built programmatically) ─────────────────────────── -->
    <LinearLayout
        android:id="@+id/keyboard_rows_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="3dp"/>

</LinearLayout>