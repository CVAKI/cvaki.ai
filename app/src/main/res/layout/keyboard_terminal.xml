<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ── Top bar ────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#001A00">

        <!-- Shell status label -->
        <TextView
            android:id="@+id/tv_term_shell_label"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text=">_ Terminal"
            android:textColor="#00FF41"
            android:textSize="9sp"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:fontFamily="monospace"/>

        <!-- Reset button -->
        <Button
            android:id="@+id/btn_term_restart"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:text="↺"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:background="#0A1A0A"
            android:padding="0dp"
            android:stateListAnimator="@null"/>

        <!-- Toggle output height -->
        <Button
            android:id="@+id/btn_toggle_output"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="▲ Out"
            android:textSize="9sp"
            android:textColor="#000000"
            android:background="#00FF41"
            android:padding="0dp"
            android:stateListAnimator="@null"/>

        <!-- LIVE toggle switch — right side, glows green when ON -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:background="#001200">

            <TextView
                android:id="@+id/tv_live_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="#444444"
                android:textSize="8sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:layout_marginEnd="4dp"/>

            <Switch
                android:id="@+id/switch_live_import"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:showText="false"
                android:checked="false"
                android:thumbTint="#444444"
                android:trackTint="#1A1A1A"
                android:scaleX="0.85"
                android:scaleY="0.85"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Output panel (collapsible) ────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/sv_terminal_output"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#000000"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tv_terminal_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF41"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="4dp"
            android:textIsSelectable="true"
            android:text="CVA Terminal v1.0&#10;$ "/>

    </ScrollView>

    <!-- ── Input line ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#001200">

        <TextView
            android:id="@+id/tv_term_input_line"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="$ █"
            android:textColor="#00FF41"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:ellipsize="start"/>

    </LinearLayout>

    <!-- ── Always-visible terminal keyboard ──────────────────────────────── -->
    <LinearLayout
        android:id="@+id/terminal_keyboard_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#000814"
        android:padding="2dp"/>

    <!-- Legacy stub — kept so existing code references don't break -->
    <LinearLayout
        android:id="@+id/terminal_slide_keyboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"/>

</LinearLayout>