<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808"
    android:scrollbarThumbVertical="@android:color/transparent"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="48dp">

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  HERO                                                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/bg_hero">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.04"
                android:background="#FF6A1A"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="116dp"
                    android:layout_height="116dp"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="116dp"
                        android:layout_height="116dp"
                        android:background="@drawable/bg_logo_ring"
                        android:layout_gravity="center"
                        android:alpha="0.6"/>

                    <ImageView
                        android:id="@+id/iv_logo"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:src="@drawable/cvaki"/>

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CVA"
                    android:textColor="#FF6A1A"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COGNITIVE  VIRTUAL  AGENT"
                    android:textColor="#555555"
                    android:textSize="10sp"
                    android:letterSpacing="0.4"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="22dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_status_chip"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp">

                    <View
                        android:id="@+id/view_status_dot"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/ic_dot_orange"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INITIALIZING"
                        android:textColor="#FF6A1A"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="monospace"/>

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Gradient divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/divider_orange"
            android:layout_marginBottom="8dp"/>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  CONTENT                                                     -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/ll_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- ──────────────────────────────────────────────── -->
            <!--  § 1  KEYBOARD SETUP                             -->
            <!-- ──────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/section_keyboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View android:layout_width="3dp" android:layout_height="18dp"
                        android:background="#FF6A1A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="KEYBOARD SETUP"
                        android:textColor="#FF6A1A" android:textSize="11sp"
                        android:letterSpacing="0.3" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="01" android:textColor="#2A2A2A"
                        android:textSize="22sp" android:fontFamily="sans-serif-black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <Button android:id="@+id/btn_enable_ime"
                        android:layout_width="match_parent" android:layout_height="54dp"
                        android:text="① ENABLE CVA KEYBOARD" android:textSize="12sp"
                        android:letterSpacing="0.15" android:textColor="#CCCCCC"
                        android:background="@drawable/bg_btn_dark" android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-medium" android:stateListAnimator="@null"/>

                    <Button android:id="@+id/btn_switch_ime"
                        android:layout_width="match_parent" android:layout_height="54dp"
                        android:text="② SWITCH TO CVA KEYBOARD" android:textSize="12sp"
                        android:letterSpacing="0.15" android:textColor="#0A0A0A"
                        android:background="@drawable/bg_btn_primary"
                        android:fontFamily="sans-serif-black" android:stateListAnimator="@null"/>

                </LinearLayout>
            </LinearLayout>

            <!-- ──────────────────────────────────────────────── -->
            <!--  § 2  AI PROVIDER                                -->
            <!-- ──────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/section_provider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View android:layout_width="3dp" android:layout_height="18dp"
                        android:background="#FF6A1A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="AI PROVIDER"
                        android:textColor="#FF6A1A" android:textSize="11sp"
                        android:letterSpacing="0.3" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="02" android:textColor="#2A2A2A"
                        android:textSize="22sp" android:fontFamily="sans-serif-black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <RadioGroup android:id="@+id/radio_provider"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="16dp">

                        <RadioButton android:id="@+id/rb_anthropic"
                            android:layout_width="0dp" android:layout_height="48dp"
                            android:layout_weight="1" android:text="CLAUDE"
                            android:textColor="#AAAAAA" android:buttonTint="#FF6A1A"
                            android:textSize="10sp" android:gravity="center"
                            android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                            android:layout_marginEnd="4dp"/>

                        <RadioButton android:id="@+id/rb_gemini"
                            android:layout_width="0dp" android:layout_height="48dp"
                            android:layout_weight="1" android:text="GEMINI"
                            android:textColor="#AAAAAA" android:buttonTint="#FF6A1A"
                            android:textSize="10sp" android:gravity="center"
                            android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                            android:layout_marginEnd="4dp"/>

                        <RadioButton android:id="@+id/rb_openrouter"
                            android:layout_width="0dp" android:layout_height="48dp"
                            android:layout_weight="1" android:text="LLAMA"
                            android:textColor="#AAAAAA" android:buttonTint="#FF6A1A"
                            android:textSize="10sp" android:gravity="center"
                            android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"/>

                        <RadioButton android:id="@+id/rb_groq"
                            android:layout_width="0dp" android:layout_height="48dp"
                            android:layout_weight="1" android:text="GROQ ⚡"
                            android:textColor="#AAAAAA" android:buttonTint="#FF6A1A"
                            android:textSize="10sp" android:gravity="center"
                            android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"/>

                    </RadioGroup>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="ANTHROPIC  ·  CLAUDE" android:textColor="#3A3A3A"
                        android:textSize="9sp" android:letterSpacing="0.25"
                        android:fontFamily="sans-serif-medium" android:paddingBottom="5dp"/>
                    <EditText android:id="@+id/et_key_anthropic"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:hint="sk-ant-api03-···" android:textColor="#FFFFFF"
                        android:textColorHint="#2A2A2A" android:background="@drawable/bg_edittext"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:inputType="textPassword" android:fontFamily="monospace"
                        android:textSize="13sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="GOOGLE  ·  GEMINI" android:textColor="#3A3A3A"
                        android:textSize="9sp" android:letterSpacing="0.25"
                        android:fontFamily="sans-serif-medium" android:paddingBottom="5dp"/>
                    <EditText android:id="@+id/et_key_gemini"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:hint="AIza···" android:textColor="#FFFFFF"
                        android:textColorHint="#2A2A2A" android:background="@drawable/bg_edittext"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:inputType="textPassword" android:fontFamily="monospace"
                        android:textSize="13sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="OPENROUTER  ·  LLAMA 3.3 70B  ·  FREE" android:textColor="#3A3A3A"
                        android:textSize="9sp" android:letterSpacing="0.25"
                        android:fontFamily="sans-serif-medium" android:paddingBottom="5dp"/>
                    <EditText android:id="@+id/et_key_openrouter"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:hint="sk-or-v1-···" android:textColor="#FFFFFF"
                        android:textColorHint="#2A2A2A" android:background="@drawable/bg_edittext"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:inputType="textPassword" android:fontFamily="monospace"
                        android:textSize="13sp" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="GROQ  ·  LLAMA 3.3 70B  ·  FREE ⚡" android:textColor="#3A3A3A"
                        android:textSize="9sp" android:letterSpacing="0.25"
                        android:fontFamily="sans-serif-medium" android:paddingBottom="5dp"/>
                    <EditText android:id="@+id/et_key_groq"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:hint="gsk_···" android:textColor="#FFFFFF"
                        android:textColorHint="#2A2A2A" android:background="@drawable/bg_edittext"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:inputType="textPassword" android:fontFamily="monospace"
                        android:textSize="13sp" android:layout_marginBottom="16dp"/>

                    <Button android:id="@+id/btn_save_keys"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="SAVE  KEYS  &amp;  PROVIDER"
                        android:textSize="13sp" android:letterSpacing="0.25"
                        android:textColor="#0A0A0A" android:background="@drawable/bg_btn_primary"
                        android:fontFamily="sans-serif-black" android:stateListAnimator="@null"/>

                </LinearLayout>
            </LinearLayout>

            <!-- ──────────────────────────────────────────────── -->
            <!--  § 3  PERMISSIONS                                -->
            <!-- ──────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/section_permissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View android:layout_width="3dp" android:layout_height="18dp"
                        android:background="#FF6A1A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="PERMISSIONS"
                        android:textColor="#FF6A1A" android:textSize="11sp"
                        android:letterSpacing="0.3" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="03" android:textColor="#2A2A2A"
                        android:textSize="22sp" android:fontFamily="sans-serif-black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:padding="12dp">

                    <Button android:id="@+id/btn_grant_permissions"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="GRANT ALL PERMISSIONS" android:textSize="11sp"
                        android:letterSpacing="0.15" android:textColor="#CCCCCC"
                        android:background="@drawable/bg_btn_dark" android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-medium" android:stateListAnimator="@null"/>

                    <Button android:id="@+id/btn_overlay_permission"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="GRANT OVERLAY PERMISSION" android:textSize="11sp"
                        android:letterSpacing="0.15" android:textColor="#CCCCCC"
                        android:background="@drawable/bg_btn_dark" android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-medium" android:stateListAnimator="@null"/>

                    <Button android:id="@+id/btn_accessibility"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="ENABLE ACCESSIBILITY SERVICE" android:textSize="11sp"
                        android:letterSpacing="0.15" android:textColor="#FF6A1A"
                        android:background="@drawable/bg_btn_ghost"
                        android:fontFamily="sans-serif-medium" android:stateListAnimator="@null"/>

                </LinearLayout>
            </LinearLayout>

            <!-- ──────────────────────────────────────────────── -->
            <!--  § 4  CVA OVERLAY                                -->
            <!-- ──────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/section_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View android:layout_width="3dp" android:layout_height="18dp"
                        android:background="#FF6A1A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="CVA OVERLAY"
                        android:textColor="#FF6A1A" android:textSize="11sp"
                        android:letterSpacing="0.3" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="04" android:textColor="#2A2A2A"
                        android:textSize="22sp" android:fontFamily="sans-serif-black"/>
                </LinearLayout>

                <Button android:id="@+id/btn_toggle_overlay"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:text="▶  START CVA FLOATING OVERLAY"
                    android:textSize="12sp" android:letterSpacing="0.15"
                    android:textColor="#FF6A1A" android:background="@drawable/bg_btn_ghost"
                    android:fontFamily="sans-serif-medium" android:stateListAnimator="@null"/>

            </LinearLayout>

            <!-- ──────────────────────────────────────────────── -->
            <!--  § 5  MEMORY                                     -->
            <!-- ──────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/section_memory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View android:layout_width="3dp" android:layout_height="18dp"
                        android:background="#FF6A1A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="CVAKI MEMORY"
                        android:textColor="#FF6A1A" android:textSize="11sp"
                        android:letterSpacing="0.3" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="05" android:textColor="#2A2A2A"
                        android:textSize="22sp" android:fontFamily="sans-serif-black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button android:id="@+id/btn_view_memory"
                        android:layout_width="0dp" android:layout_height="50dp"
                        android:layout_weight="1" android:text="VIEW FILES"
                        android:textSize="11sp" android:letterSpacing="0.1"
                        android:textColor="#AAAAAA" android:background="@drawable/bg_btn_dark"
                        android:layout_marginEnd="6dp" android:fontFamily="sans-serif-medium"
                        android:stateListAnimator="@null"/>

                    <Button android:id="@+id/btn_clear_memory"
                        android:layout_width="0dp" android:layout_height="50dp"
                        android:layout_weight="1" android:text="CLEAR MEMORY"
                        android:textSize="11sp" android:letterSpacing="0.1"
                        android:textColor="#FF4444" android:background="@drawable/bg_danger_btn"
                        android:fontFamily="sans-serif-medium" android:stateListAnimator="@null"/>

                </LinearLayout>
            </LinearLayout>

            <!-- ──────────────────────────────────────────────── -->
            <!--  FOOTER                                          -->
            <!-- ──────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/divider_orange"
                android:layout_marginBottom="18dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CVA" android:textColor="#FF6A1A" android:textSize="10sp"
                    android:letterSpacing="0.2" android:fontFamily="sans-serif-black"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  ·  BRAINGODS  ·  v1.0" android:textColor="#2A2A2A"
                    android:textSize="10sp" android:letterSpacing="0.2" android:fontFamily="monospace"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>