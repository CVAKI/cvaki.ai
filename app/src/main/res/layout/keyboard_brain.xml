<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- ── Chat bubble scroll area ──────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/sv_brain_output"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#0A0A0A"
        android:scrollbars="none"
        android:fillViewport="true">

        <!-- Bubble container — messages injected here programmatically -->
        <LinearLayout
            android:id="@+id/tv_brain_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false" />

    </ScrollView>

    <!-- Thin orange divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF6A1A" />

    <!-- ── Input indicator ───────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_brain_input"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:text="> █"
        android:textColor="#FF6A1A"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:background="#0F0F0F"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:gravity="center_vertical" />

    <!-- ── Action bar ────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:background="#0A0A0A">

        <Button
            android:id="@+id/btn_brain_import_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⬆ Import"
            android:textSize="10sp"
            android:textColor="#FF6A1A"
            android:background="#141414"
            android:padding="0dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#1A1A1A" />

        <Button
            android:id="@+id/btn_api_key"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="↺ Refresh"
            android:textSize="10sp"
            android:textColor="#FF6A1A"
            android:background="#141414"
            android:padding="0dp" />

        <!-- kept for Java compat only -->
        <Button android:id="@+id/btn_brain_import_right"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone" android:padding="0dp" />
        <Button android:id="@+id/btn_show_brain_keyboard"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone" android:padding="0dp" />

    </LinearLayout>

    <!-- ── Agent status ticker (shown during agentic execution) ────────────── -->
    <TextView
        android:id="@+id/tv_agent_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="0dp"
        android:text=""
        android:textColor="#00FF88"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:background="#050505"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <!-- ── Brain keyboard — ALWAYS VISIBLE ──────────────────────────────── -->
    <LinearLayout
        android:id="@+id/brain_slide_keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0A0A"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/brain_keyboard_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="2dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

</LinearLayout>